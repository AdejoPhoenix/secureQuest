# Database
POSTGRES_USER=gameuser
POSTGRES_PASSWORD=gamepassword
POSTGRES_DB=secgame
DATABASE_URL=postgresql://gameuser:gamepassword@db:5432/secgame

# Backend
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Frontend (Flask)
FLASK_SECRET_KEY=change-me-to-another-random-secret
BACKEND_URL=http://backend:8000
# When running locally without Docker use: http://localhost:8000

# Set this on Render to your frontend's public URL (for CORS)
FRONTEND_URL=https://your-frontend.onrender.com
